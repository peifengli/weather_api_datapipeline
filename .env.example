# =============================================================================
# Weather API Data Pipeline - Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# =============================================================================

# --- OpenWeatherMap API ---
OPENWEATHERMAP_API_KEY=your_openweather_api_key_here
WEATHER_LAT=40.7143
WEATHER_LON=-74.006
WEATHER_CITY=new_york

# --- AWS Configuration (production) ---
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_PROFILE=default

# --- S3 Buckets ---
S3_RAW_BUCKET=weatherdata-raw-prod
S3_PROCESSED_BUCKET=weatherdata-processed-prod
S3_ATHENA_RESULTS_BUCKET=weatherdata-athena-results-prod

# --- Athena ---
ATHENA_DATABASE=weather_db
ATHENA_WORKGROUP=weather_workgroup

# --- Airflow ---
AIRFLOW_UID=50000
AIRFLOW_GID=0
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__CORE__EXECUTOR=CeleryExecutor
AIRFLOW__CORE__LOAD_EXAMPLES=false

# --- LocalStack (local dev / CI) ---
LOCALSTACK_HOST=localstack
AWS_ENDPOINT_URL=http://localstack:4566
# Use test credentials with LocalStack
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# --- DBT ---
DBT_PROFILES_DIR=./dbt
DBT_TARGET=local   # local | dev | prod

# --- Superset (local visualization) ---
SUPERSET_SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars

# --- Environment ---
ENVIRONMENT=local   # local | dev | prod
