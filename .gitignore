# =============================================================================
# Secrets & local config — NEVER commit these
# =============================================================================
.env
*.pem
*.key
secrets/

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =============================================================================
# Terraform
# =============================================================================
**/.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info
.terraform.lock.hcl
crash.log
override.tf
override.tf.json

# =============================================================================
# DBT
# =============================================================================
dbt/target/
dbt/dbt_packages/
dbt/logs/

# =============================================================================
# Airflow runtime artifacts (mounted volumes, not source)
# =============================================================================
logs/
dags/
plugins/

# =============================================================================
# IDE & OS
# =============================================================================
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# =============================================================================
# Claude Code local settings
# =============================================================================
.claude/
