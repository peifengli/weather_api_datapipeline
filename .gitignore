# =============================================================================
# Secrets & local config — NEVER commit these
# =============================================================================
.env
*.pem
*.key
secrets/

# =============================================================================
# Python
# =============================================================================
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Testing & coverage
# =============================================================================
.pytest_cache/
.coverage
coverage.xml
htmlcov/

# =============================================================================
# Terraform
# =============================================================================
**/.terraform/
*.tfstate
*.tfstate.*
*.tfstate.lock.info
.terraform.lock.hcl
*.tfvars
*.tfvars.json
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
.terraformrc
terraform.rc

# =============================================================================
# DBT
# =============================================================================
dbt/target/
dbt/dbt_packages/
dbt/logs/

# =============================================================================
# Airflow runtime artifacts (mounted volumes, not source)
# =============================================================================
logs/
plugins/
# Exclude root-level dags/ volume mount but NOT airflow/dags/ source
/dags/

# =============================================================================
# IDE & OS
# =============================================================================
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# =============================================================================
# Local data files (generated by scripts/s3_to_duckdb.py)
# =============================================================================
data/*.db
data/*.duckdb

# =============================================================================
# Claude Code local settings
# =============================================================================
.claude/
